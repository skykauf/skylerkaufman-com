# Copy to .env and adjust, or set in Vercel project env vars.
PORT=3000
# Preferred provider: OpenAI (tool calling is most reliable here)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Fallback provider: Hugging Face router (OpenAI-compatible endpoint)
HF_TOKEN=hf_xxx
HF_MODEL=meta-llama/Meta-Llama-3-8B-Instruct
# Base for OpenAI-compatible API (must end up as .../v1/chat/completions)
HF_API_URL=https://router.huggingface.co/v1

# Optional. Needed for query_db, Supabase bootstrap, and (on Vercel) forwarded to the FIVB GitHub workflow.
# Supabase: Project Settings → Database → Connection string → URI (use the database password, not anon/service_role keys).
# Aliases: POSTGRES_URL, POSTGRES_URL_NON_POOLING, SUPABASE_DB_URL, or SUPABASE_DB_HOST + SUPABASE_DB_PASSWORD (see lib/resolve-database-url.js).
DATABASE_URL=postgres://user:password@host:5432/dbname
# Supabase Auth (Google OAuth + saved chat history)
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_ANON_KEY=eyJ...
# Local only: set PGSSLMODE=disable if you use plain local Postgres without SSL.

# Vercel only — daily FIVB pipeline dispatch (see README)
# CRON_SECRET=long-random-string
# GITHUB_PAT=ghp_...   # repo + workflow (classic) or fine-grained Actions: write
# GITHUB_REPO=skykauf/skylerkaufman-com
# GITHUB_DISPATCH_REF=main
# Optional: protect /api/chat-tools-smoke
# CHAT_SMOKE_TOKEN=long-random-string
