# Copy to .env and adjust, or set in Vercel project env vars.
PORT=3000
HF_TOKEN=hf_xxx
HF_MODEL=meta-llama/Meta-Llama-3-8B-Instruct
# Base for OpenAI-compatible API (must end up as .../v1/chat/completions)
HF_API_URL=https://router.huggingface.co/v1

# Optional. Needed for query_db, Supabase bootstrap, and (on Vercel) forwarded to the FIVB GitHub workflow.
DATABASE_URL=postgres://user:password@host:5432/dbname
# Local only: set PGSSLMODE=disable if you use plain local Postgres without SSL.

# Vercel only — daily FIVB pipeline dispatch (see README)
# CRON_SECRET=long-random-string
# GITHUB_PAT=ghp_...   # repo + workflow (classic) or fine-grained Actions: write
# GITHUB_REPO=skykauf/skylerkaufman-com
# GITHUB_DISPATCH_REF=main
